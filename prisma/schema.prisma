// ============================================================
// IAM Sales CRM - Database Schema (نسخه نهایی با ماژولار Industry)
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================

enum UserRole {
  ADMIN
  MANAGER
  REP
  BOARDS
}

enum SsoProviderType {
  OIDC
  SAML
}

enum LegacyPipelineStage {
  LEAD
  CONTACTED
  INTERESTED
  QUALIFIED
  NEEDS_ASSESSMENT
  PENDING_PRE_INVOICE_APPROVAL
  POC_PILOT_SCHEDULED
  POC_PILOT_IN_PROGRESS
  PENDING_POC_PILOT_APPROVAL
  PENDING_PAYMENT_INVOICE_APPROVAL
  INSTALLATION_SCHEDULED
  INSTALLATION_IN_PROGRESS
  PENDING_CUSTOMER_ACCEPTANCE
  DONE
  ON_HOLD
  LOST
  NO_RESPONSE

  @@map("PipelineStage")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  STRATEGIC
}

enum CompanyOwnership {
  PRIVATE
  STATE
  SEMI_STATE
  PUBLIC_LISTED
  BANK
  HOLDING
}

enum CompanyActivityStatus {
  ACTIVE
  INACTIVE
  MERGED
  UNKNOWN
}

enum CompanyLegalDocumentType {
  OFFICIAL_GAZETTE
  LATEST_CHANGES
}

enum PersonEducationDegree {
  DIPLOMA
  ASSOCIATE
  BACHELOR
  PHD
  POSTDOC
}

enum ActivityType {
  CALL
  EMAIL
  LINKEDIN_MESSAGE
  LINKEDIN_ENGAGEMENT
  MEETING
  NOTE
  STAGE_CHANGE
}

enum SocialPlatform {
  LINKEDIN
  INSTAGRAM
  TELEGRAM
  BALE
  EITAA
  SOROUSH
  ROOBIKA
  APARAT
  YOUTUBE
  WEBSITE
}

enum CommercialDocumentType {
  PROPOSAL
  PROFORMA
  CONTRACT
}

enum CommercialDocumentStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  SIGNED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CHECK
  CARD
  OTHER
}

enum FileAttachmentEntityType {
  OPPORTUNITY
  COMMERCIAL_DOCUMENT
  PAYMENT
  COMPANY_LEGAL_DOCUMENT
}

enum AttachmentStorageProvider {
  LOCAL
  MINIO
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum MeetingMode {
  IN_PERSON
  ONLINE
  HYBRID
}

enum NotificationType {
  SYSTEM
  TASK_CREATED
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  TASK_COMPLETED
  TASK_RESCHEDULED
  OPPORTUNITY_UPDATED
  COMMERCIAL_DOCUMENT_UPDATED
  PAYMENT_UPDATED
  ATTACHMENT_UPLOADED
  MEETING_REMINDER
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationEntityType {
  TASK
  COMPANY
  PERSON
  OPPORTUNITY
  COMMERCIAL_DOCUMENT
  PAYMENT
  ATTACHMENT
  MEETING
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

// ============================================================
// Users & Auth
// ============================================================

model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  passwordHash String
  role         UserRole @default(REP)
  roleId       String?
  assignedRole Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  team         String?
  teamId       String?
  teamRef      Team?    @relation("UserPrimaryTeam", fields: [teamId], references: [id], onDelete: SetNull)
  isActive     Boolean  @default(true)

  organizationId String       @default("00000000-0000-4000-8000-000000000001")
  organization   Organization @relation(fields: [organizationId], references: [id])

  passwordChangedAt   DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedCompanies          Company[]                 @relation("CompanyOwner")
  archivedCompanies       Company[]                 @relation("CompanyArchivedBy")
  ownedOpportunities      Opportunity[]             @relation("OpportunityOwner")
  archivedOpportunities   Opportunity[]             @relation("OpportunityArchivedBy")
  opportunityStageChanges OpportunityStageHistory[]
  activities              Activity[]
  completedActivities     Activity[]                @relation("ActivityCompletedBy")
  stageChangesMade        PipelineStageHistory[]
  passkeys                UserPasskey[]
  externalIdentities      ExternalIdentity[]
  ssoLoginTickets         SsoLoginTicket[]
  refreshSessions         RefreshSession[]

  assignedTasks  Task[] @relation("TaskAssignedTo")
  createdTasks   Task[] @relation("TaskCreatedBy")
  completedTasks Task[] @relation("TaskCompletedBy")

  organizedMeetings      Meeting[]         @relation("MeetingOrganizer")
  createdMeetings        Meeting[]         @relation("MeetingCreatedBy")
  completedMeetings      Meeting[]         @relation("MeetingCompletedBy")
  cancelledMeetings      Meeting[]         @relation("MeetingCancelledBy")
  meetingAssignments     MeetingAssignee[] @relation("MeetingAssignedUser")
  meetingAssignmentsMade MeetingAssignee[] @relation("MeetingAssignedBy")

  notifications       Notification[] @relation("NotificationRecipient")
  notificationActions Notification[] @relation("NotificationActor")
  managedTeams        Team[]         @relation("TeamManager")

  @@index([organizationId])
  @@index([teamId])
  @@index([roleId])
  @@map("users")
}

model Team {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  description String?

  managerId String?
  manager   User?   @relation("TeamManager", fields: [managerId], references: [id], onDelete: SetNull)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String       @default("00000000-0000-4000-8000-000000000001")
  organization   Organization @relation(fields: [organizationId], references: [id])

  members User[] @relation("UserPrimaryTeam")

  @@index([managerId])
  @@index([isActive])
  @@index([organizationId])
  @@map("teams")
}

model Organization {
  id String @id @default(uuid())

  code String @unique
  name String

  status OrganizationStatus @default(ACTIVE)

  timezone String @default("Asia/Tehran")
  locale   String @default("fa-IR")

  settings Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  teams           Team[]
  companies       Company[]
  opportunities   Opportunity[]
  tasks           Task[]
  notifications   Notification[]
  fileAttachments FileAttachment[]
  auditLogs       AuditLog[]
  meetings        Meeting[]

  @@index([status])
  @@index([createdAt])
  @@map("organizations")
}

model UserPasskey {
  id                   String    @id @default(uuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId         String    @unique
  credentialPublicKey  Bytes
  counter              Int       @default(0)
  deviceName           String?
  transports           String[]
  backedUp             Boolean   @default(false)
  credentialDeviceType String?
  lastUsedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
  @@map("user_passkeys")
}

model SsoProvider {
  id       String          @id @default(uuid())
  name     String
  type     SsoProviderType
  isActive Boolean         @default(true)

  autoProvision  Boolean   @default(false)
  defaultRole    UserRole?
  allowedDomains String[]  @default([])

  // OIDC configuration
  issuer           String?
  clientId         String?
  clientSecretEnc  String?
  authorizationUrl String?
  tokenUrl         String?
  userInfoUrl      String?
  jwksUrl          String?
  scopes           String[] @default(["openid", "profile", "email"])

  // SAML configuration
  entityId             String?
  ssoUrl               String?
  x509Certificate      String?
  signRequests         Boolean @default(false)
  wantAssertionsSigned Boolean @default(true)
  wantResponseSigned   Boolean @default(false)

  // Attribute mapping
  emailAttribute  String?
  nameAttribute   String?
  groupsAttribute String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  externalIdentities ExternalIdentity[]
  loginTickets       SsoLoginTicket[]

  @@index([type])
  @@index([isActive])
  @@map("sso_providers")
}

model ExternalIdentity {
  id         String @id @default(uuid())
  userId     String
  providerId String

  subject String
  email   String?

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider SsoProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, subject])
  @@index([userId])
  @@index([email])
  @@map("external_identities")
}

model SsoLoginTicket {
  id         String @id @default(uuid())
  ticketHash String @unique

  userId     String
  providerId String?

  expiresAt  DateTime
  consumedAt DateTime?

  createdAt DateTime @default(now())

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider SsoProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([providerId])
  @@index([expiresAt])
  @@index([consumedAt])
  @@map("sso_login_tickets")
}

model RefreshSession {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String @unique

  userAgent String?
  ipAddress String?

  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  expiresAt  DateTime

  revokedAt           DateTime?
  revokedReason       String?
  replacedBySessionId String?

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([userId, revokedAt, expiresAt])
  @@map("refresh_sessions")
}

// ============================================================
// Company
// ============================================================

model Company {
  id       String @id @default(uuid())
  leadCode String @unique @default(uuid())

  legalName          String
  brandName          String?
  registrationNo     String?
  registrationNumber String?
  nationalId         String?
  economicCode       String?
  establishmentDate  DateTime?
  foundedYear        Int?
  companyType        String?
  ownership          CompanyOwnership?
  activityStatus     CompanyActivityStatus @default(UNKNOWN)
  activityGroup      String?
  marketSize         String?

  industryId  String?
  industryRef Industry? @relation("CompanyIndustry", fields: [industryId], references: [id], onDelete: SetNull)

  // Deprecated compatibility snapshot. New writes should resolve from Industry.
  industry String?

  parentCompanyId     String?
  parentCompany       Company?                   @relation("CompanyHierarchy", fields: [parentCompanyId], references: [id])
  subsidiaries        Company[]                  @relation("CompanyHierarchy")
  parentRelations     CompanyHierarchyRelation[] @relation("CompanyHierarchyParent")
  subsidiaryRelations CompanyHierarchyRelation[] @relation("CompanyHierarchySubsidiary")

  website            String?
  publicEmail        String?
  headOfficeProvince String?
  headOfficeCity     String?
  headOfficeAddress  String?
  postalCode         String?
  centralPhone       String?

  registeredCapital Decimal? @db.Decimal(24, 2)
  employeeCount     Int?
  annualRevenue     BigInt?

  ownerId String?
  owner   User?   @relation("CompanyOwner", fields: [ownerId], references: [id])

  // Deprecated pipeline compatibility fields. New sales flows belong to Opportunity.
  priority Priority            @default(MEDIUM)
  stage    LegacyPipelineStage @default(LEAD)

  sourceId  String?
  sourceRef LeadSource? @relation("CompanyLeadSource", fields: [sourceId], references: [id], onDelete: SetNull)

  // Deprecated compatibility snapshot. New writes should resolve from LeadSource.
  source         String?   @default("SAM_LIST")
  nextActionDate DateTime?

  archivedAt    DateTime?
  archivedById  String?
  archivedBy    User?     @relation("CompanyArchivedBy", fields: [archivedById], references: [id])
  archiveReason String?

  researchCompletion Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches                CompanyBranch[]
  socialChannels          CompanySocialChannel[]
  people                  Person[]
  activities              Activity[]
  callCard                CallCard?
  stageHistory            PipelineStageHistory[]
  opportunities           Opportunity[]
  tasks                   Task[]
  legalDocuments          CompanyLegalDocument[]
  personEmploymentHistory PersonEmploymentHistory[]
  meetings                Meeting[]

  organizationId String       @default("00000000-0000-4000-8000-000000000001")
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([ownerId])
  @@index([industryId])
  @@index([sourceId])
  @@index([stage])
  @@index([priority])
  @@index([industry])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([archivedAt])
  @@index([ownerId, stage])
  @@index([stage, priority])
  @@index([organizationId])
  @@index([organizationId, ownerId])
  @@map("companies")
}

model CompanyHierarchyRelation {
  id                  String   @id @default(uuid())
  parentCompanyId     String
  subsidiaryCompanyId String
  parentCompany       Company  @relation("CompanyHierarchyParent", fields: [parentCompanyId], references: [id], onDelete: Cascade)
  subsidiaryCompany   Company  @relation("CompanyHierarchySubsidiary", fields: [subsidiaryCompanyId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([parentCompanyId, subsidiaryCompanyId])
  @@index([subsidiaryCompanyId])
  @@map("company_hierarchy_relations")
}

model CompanyLegalDocument {
  id           String                   @id @default(uuid())
  companyId    String
  company      Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type         CompanyLegalDocumentType
  title        String
  description  String?
  documentDate DateTime?
  attachmentId String?                  @unique
  createdById  String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([companyId, type])
  @@map("company_legal_documents")
}

// ============================================================
// Company Branch
// ============================================================

model CompanyBranch {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name    String?
  city    String?
  address String?
  phone   String?

  @@index([companyId])
  @@map("company_branches")
}

// ============================================================
// Company Social Channel
// ============================================================

model CompanySocialChannel {
  id        String         @id @default(uuid())
  companyId String
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  platform  SocialPlatform
  handle    String

  @@index([companyId])
  @@index([platform])
  @@map("company_social_channels")
}

// ============================================================
// Person (مخاطب)
// ============================================================

model Person {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  fullName       String
  title          String?
  department     String?
  seniorityLevel String?
  personaTag     String?
  tenureInRole   String?
  expertiseArea  String?
  linkedinActive Boolean?
  bestChannel    String?

  isPrimaryContact   Boolean @default(false)
  isSecondaryContact Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // فیلدهای قدیمی (برای سازگاری)
  linkedinUrl String?
  email       String?
  phone       String?

  contacts           PersonContact[]
  socials            PersonSocial[]
  tasks              Task[]
  employmentHistory  PersonEmploymentHistory[]
  educationHistory   PersonEducationHistory[]
  meetingAttendances MeetingAttendee[]

  activities           Activity[]
  primaryOpportunities Opportunity[] @relation("OpportunityPrimaryContact")

  @@index([companyId])
  @@index([personaTag])
  @@index([isPrimaryContact])
  @@map("people")
}

model PersonEmploymentHistory {
  id                  String                     @id @default(uuid())
  personId            String
  person              Person                     @relation(fields: [personId], references: [id], onDelete: Cascade)
  companyId           String
  company             Company                    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyNameSnapshot String?
  description         String?
  positions           PersonEmploymentPosition[]
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@unique([personId, companyId])
  @@index([companyId])
  @@map("person_employment_history")
}

model PersonEmploymentPosition {
  id                  String                  @id @default(uuid())
  employmentHistoryId String
  employmentHistory   PersonEmploymentHistory @relation(fields: [employmentHistoryId], references: [id], onDelete: Cascade)
  title               String
  startDate           DateTime?
  endDate             DateTime?
  isCurrent           Boolean                 @default(false)
  description         String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([employmentHistoryId])
  @@map("person_employment_positions")
}

model PersonEducationHistory {
  id                     String                 @id @default(uuid())
  personId               String
  person                 Person                 @relation(fields: [personId], references: [id], onDelete: Cascade)
  degree                 PersonEducationDegree?
  degreeNameSnapshot     String?
  universityId           String?
  university             University?            @relation(fields: [universityId], references: [id], onDelete: SetNull)
  universityNameSnapshot String?
  educationDate          DateTime?
  description            String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  @@index([personId])
  @@index([universityId])
  @@map("person_education_history")
}

model University {
  id               String                   @id @default(uuid())
  name             String                   @unique
  code             String?                  @unique
  isActive         Boolean                  @default(true)
  description      String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  educationHistory PersonEducationHistory[]

  @@index([isActive])
  @@map("universities")
}

// ============================================================
// Person Contact (اطلاعات تماس)
// ============================================================

model PersonContact {
  id       String @id @default(uuid())
  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  typeOptionId String?
  typeOption   LookupOption? @relation("PersonContactTypeOption", fields: [typeOptionId], references: [id], onDelete: SetNull)

  // Deprecated compatibility snapshot. New writes should resolve from LookupOption(group = contact_types).
  type String

  value     String
  isPrimary Boolean @default(false)
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([personId, type, value])
  @@index([personId])
  @@index([type])
  @@index([typeOptionId])
  @@map("person_contacts")
}

// ============================================================
// Person Social (شبکه‌های اجتماعی)
// ============================================================

model PersonSocial {
  id       String @id @default(uuid())
  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  platformOptionId String?
  platformOption   LookupOption? @relation("PersonSocialPlatformOption", fields: [platformOptionId], references: [id], onDelete: SetNull)

  // Deprecated compatibility snapshot. New writes should resolve from LookupOption(group = social_types).
  platform String

  handle    String
  isPrimary Boolean @default(false)
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([personId, platform, handle])
  @@index([personId])
  @@index([platform])
  @@index([platformOptionId])
  @@map("person_socials")
}

// ============================================================
// Activity (فعالیت‌ها)
// ============================================================

model Activity {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  personId  String?
  person    Person? @relation(fields: [personId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  type           ActivityType
  notes          String?
  outcome        String?
  occurredAt     DateTime     @default(now())
  nextActionDate DateTime?
  completedAt    DateTime?
  completedById  String?
  completedBy    User?        @relation("ActivityCompletedBy", fields: [completedById], references: [id])
  completionNote String?
  opportunityId  String?
  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([nextActionDate])
  @@index([completedAt])
  @@index([type])
  @@index([occurredAt])
  @@index([userId, nextActionDate])
  @@index([companyId, occurredAt])
  @@index([opportunityId])
  @@map("activities")
}

model Opportunity {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ownerId String?
  owner   User?   @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  title       String
  description String?

  stageId  String
  stage    PipelineStage @relation(fields: [stageId], references: [id])
  priority Priority      @default(MEDIUM)

  estimatedValue    Decimal?  @db.Decimal(18, 2)
  expectedCloseDate DateTime?

  sourceOptionId String?
  sourceOption   LookupOption? @relation("OpportunitySourceOption", fields: [sourceOptionId], references: [id], onDelete: SetNull)

  // Backward-compatible snapshot. New writes should prefer sourceOptionId/opportunitySource.
  source String?

  primaryContactId String?
  primaryContact   Person? @relation("OpportunityPrimaryContact", fields: [primaryContactId], references: [id], onDelete: SetNull)

  probability Int?
  competitor  String?
  lostReason  String?
  wonAt       DateTime?
  lostAt      DateTime?

  archivedAt    DateTime?
  archivedById  String?
  archivedBy    User?     @relation("OpportunityArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)
  archiveReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stageHistories      OpportunityStageHistory[]
  activities          Activity[]
  lineItems           OpportunityLineItem[]
  commercialDocuments OpportunityCommercialDocument[]
  payments            OpportunityPayment[]
  tasks               Task[]
  meetings            Meeting[]
  organizationId      String                          @default("00000000-0000-4000-8000-000000000001")
  organization        Organization                    @relation(fields: [organizationId], references: [id])

  @@index([companyId])
  @@index([ownerId])
  @@index([stageId])
  @@index([priority])
  @@index([sourceOptionId])
  @@index([primaryContactId])
  @@index([expectedCloseDate])
  @@index([archivedAt])
  @@index([ownerId, stageId])
  @@index([organizationId])
  @@index([organizationId, ownerId])
  @@index([organizationId, stageId])
  @@index([organizationId, sourceOptionId])
  @@map("opportunities")
}

model OpportunityCommercialDocument {
  id            String      @id @default(uuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  type   CommercialDocumentType
  status CommercialDocumentStatus @default(DRAFT)

  number  String?
  version Int     @default(1)

  title       String
  description String?

  amount   Decimal? @db.Decimal(18, 2)
  currency String   @default("IRR")

  validUntil DateTime?
  issuedAt   DateTime?
  sentAt     DateTime?
  acceptedAt DateTime?
  rejectedAt DateTime?
  signedAt   DateTime?

  fileUrl     String?
  externalRef String?
  notes       String?

  createdById String?
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments OpportunityPayment[]
  tasks    Task[]

  @@index([opportunityId])
  @@index([type])
  @@index([status])
  @@index([number])
  @@index([createdAt])
  @@map("opportunity_commercial_documents")
}

model OpportunityPayment {
  id            String      @id @default(uuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  commercialDocumentId String?
  commercialDocument   OpportunityCommercialDocument? @relation(fields: [commercialDocumentId], references: [id], onDelete: SetNull)

  status PaymentStatus @default(PENDING)

  amount   Decimal @db.Decimal(18, 2)
  currency String  @default("IRR")

  dueDate DateTime?
  paidAt  DateTime?

  method          PaymentMethod?
  referenceNumber String?
  description     String?
  notes           String?

  createdById String?
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[]

  @@index([opportunityId])
  @@index([commercialDocumentId])
  @@index([status])
  @@index([dueDate])
  @@index([paidAt])
  @@map("opportunity_payments")
}

model ProductCatalogItem {
  id               String   @id @default(uuid())
  code             String   @unique
  name             String
  description      String?
  category         String?
  unit             String?
  defaultUnitPrice Decimal  @default(0) @db.Decimal(18, 2)
  currency         String   @default("IRR")
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  lineItems OpportunityLineItem[]

  @@index([isActive, sortOrder])
  @@index([category])
  @@map("product_catalog_items")
}

model OpportunityLineItem {
  id            String      @id @default(uuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  productId String?
  product   ProductCatalogItem? @relation(fields: [productId], references: [id], onDelete: SetNull)

  productCodeSnapshot String
  productNameSnapshot String

  description String?

  quantity       Decimal @db.Decimal(18, 2)
  unitPrice      Decimal @db.Decimal(18, 2)
  discountAmount Decimal @default(0) @db.Decimal(18, 2)
  taxAmount      Decimal @default(0) @db.Decimal(18, 2)
  lineTotal      Decimal @db.Decimal(18, 2)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([opportunityId])
  @@index([productId])
  @@index([sortOrder])
  @@map("opportunity_line_items")
}

model OpportunityStageHistory {
  id            String      @id @default(uuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  fromStageId String?
  fromStage   PipelineStage? @relation("OpportunityHistoryFromStage", fields: [fromStageId], references: [id])
  toStageId   String
  toStage     PipelineStage  @relation("OpportunityHistoryToStage", fields: [toStageId], references: [id])

  changedById String?
  changedBy   User?   @relation(fields: [changedById], references: [id], onDelete: SetNull)

  note      String?
  changedAt DateTime @default(now())

  @@index([opportunityId])
  @@index([fromStageId])
  @@index([toStageId])
  @@index([changedAt])
  @@index([opportunityId, changedAt])
  @@map("opportunity_stage_histories")
}

model Task {
  id String @id @default(uuid())

  title       String
  description String?

  status   TaskStatus @default(TODO)
  priority Priority   @default(MEDIUM)

  dueAt      DateTime?
  reminderAt DateTime?

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  personId String?
  person   Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  commercialDocumentId String?
  commercialDocument   OpportunityCommercialDocument? @relation(fields: [commercialDocumentId], references: [id], onDelete: SetNull)

  paymentId String?
  payment   OpportunityPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  assignedToId String?
  assignedTo   User?   @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  completedAt    DateTime?
  completedById  String?
  completedBy    User?     @relation("TaskCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  completionNote String?

  cancelledAt  DateTime?
  cancelReason String?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String       @default("00000000-0000-4000-8000-000000000001")
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([status])
  @@index([priority])
  @@index([dueAt])
  @@index([reminderAt])
  @@index([companyId])
  @@index([personId])
  @@index([opportunityId])
  @@index([commercialDocumentId])
  @@index([paymentId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([completedAt])
  @@index([assignedToId, status, dueAt])
  @@index([organizationId])
  @@index([organizationId, assignedToId, status, dueAt])
  @@map("tasks")
}

model Meeting {
  id                 String            @id @default(uuid())
  organizationId     String
  organization       Organization      @relation(fields: [organizationId], references: [id])
  companyId          String
  company            Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  opportunityId      String?
  opportunity        Opportunity?      @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  title              String
  agenda             String?
  description        String?
  mode               MeetingMode
  location           String?
  meetingUrl         String?
  startAt            DateTime
  endAt              DateTime
  reminderAt         DateTime?
  reminderSentAt     DateTime?
  status             MeetingStatus     @default(SCHEDULED)
  organizerId        String
  organizer          User              @relation("MeetingOrganizer", fields: [organizerId], references: [id], onDelete: Restrict)
  createdById        String
  createdBy          User              @relation("MeetingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  completedAt        DateTime?
  completedById      String?
  completedBy        User?             @relation("MeetingCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  completionNote     String?
  cancelledAt        DateTime?
  cancelledById      String?
  cancelledBy        User?             @relation("MeetingCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  cancellationReason String?
  assignees          MeetingAssignee[]
  attendees          MeetingAttendee[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([organizationId, startAt])
  @@index([companyId, startAt])
  @@index([opportunityId, startAt])
  @@index([organizerId, startAt])
  @@index([status, startAt])
  @@index([reminderAt, reminderSentAt, status])
  @@map("meetings")
}

model MeetingAssignee {
  meetingId    String
  meeting      Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation("MeetingAssignedUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedById String?
  assignedBy   User?    @relation("MeetingAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@id([meetingId, userId])
  @@index([userId])
  @@map("meeting_assignees")
}

model MeetingAttendee {
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([meetingId, personId])
  @@index([personId])
  @@map("meeting_attendees")
}

model Notification {
  id String @id @default(uuid())

  recipientId String
  recipient   User   @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  type     NotificationType
  priority NotificationPriority @default(NORMAL)

  title String
  body  String?

  entityType NotificationEntityType?
  entityId   String?

  actionUrl String?
  metadata  Json?

  readAt     DateTime?
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String       @default("00000000-0000-4000-8000-000000000001")
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([recipientId])
  @@index([actorId])
  @@index([type])
  @@index([priority])
  @@index([entityType, entityId])
  @@index([readAt])
  @@index([archivedAt])
  @@index([createdAt])
  @@index([recipientId, readAt, archivedAt, createdAt])
  @@index([organizationId])
  @@index([organizationId, recipientId, readAt, archivedAt, createdAt])
  @@map("notifications")
}

// ============================================================
// Pipeline Stage History
// ============================================================

model PipelineStageHistory {
  id          String               @id @default(uuid())
  companyId   String
  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromStage   LegacyPipelineStage?
  toStage     LegacyPipelineStage
  changedById String?
  changedBy   User?                @relation(fields: [changedById], references: [id])
  changedAt   DateTime             @default(now())

  @@index([companyId])
  @@index([changedAt])
  @@index([toStage])
  @@index([companyId, changedAt])
  @@map("pipeline_stage_history")
}

model PipelineStage {
  id           String   @id @default(uuid())
  code         String   @unique
  label        String
  description  String?
  sortOrder    Int      @default(0)
  color        String?
  isActive     Boolean  @default(true)
  isTerminal   Boolean  @default(false)
  terminalType String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  opportunities            Opportunity[]
  opportunityHistoriesFrom OpportunityStageHistory[] @relation("OpportunityHistoryFromStage")
  opportunityHistoriesTo   OpportunityStageHistory[] @relation("OpportunityHistoryToStage")
  transitionsFrom          PipelineStageTransition[] @relation("TransitionFromStage")
  transitionsTo            PipelineStageTransition[] @relation("TransitionToStage")

  @@index([sortOrder])
  @@index([isActive, sortOrder])
  @@map("pipeline_stages")
}

model PipelineStageTransition {
  id          String         @id @default(uuid())
  fromStageId String?
  fromStage   PipelineStage? @relation("TransitionFromStage", fields: [fromStageId], references: [id])
  toStageId   String
  toStage     PipelineStage  @relation("TransitionToStage", fields: [toStageId], references: [id])
  role        UserRole?
  isAllowed   Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([fromStageId, toStageId, role])
  @@index([fromStageId])
  @@index([toStageId])
  @@index([role])
  @@map("pipeline_stage_transitions")
}

// ============================================================
// Call Card
// ============================================================

model CallCard {
  id        String  @id @default(uuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  primaryContactId   String?
  secondaryContactId String?

  entryAngle  String?
  painPoint   String?
  useCase     String?
  openingLine String?
  firstEmail  String?
  linkedinMsg String?
  discoveryQs Json?
  objections  Json?
  meetingAsk  String?
  callGoal    String?

  followUpNoResponseAt String?
  followUpInterestAt   String?

  qualificationCriteria    String?
  disqualificationCriteria String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([primaryContactId])
  @@index([secondaryContactId])
  @@map("call_cards")
}

// ============================================================
// Persona Library (قدیمی، حفظ شده)
// ============================================================

model PersonaLibrary {
  id               String  @id @default(uuid())
  titlePattern     String
  defaultPainPoint String?
  defaultUseCase   String?
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([titlePattern])
  @@map("persona_library")
}

model LeadSource {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companies Company[] @relation("CompanyLeadSource")

  @@index([isActive, sortOrder])
  @@map("lead_sources")
}

model LookupOption {
  id          String   @id @default(uuid())
  group       String
  code        String
  label       String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  personContactTypes    PersonContact[] @relation("PersonContactTypeOption")
  personSocialPlatforms PersonSocial[]  @relation("PersonSocialPlatformOption")
  opportunitySources    Opportunity[]   @relation("OpportunitySourceOption")

  @@unique([group, code])
  @@index([group])
  @@index([group, isActive, sortOrder])
  @@map("lookup_options")
}

model AuditLog {
  id         String  @id @default(uuid())
  actorId    String?
  entityType String
  entityId   String?
  action     String
  before     Json?
  after      Json?
  metadata   Json?

  requestId     String?
  ipAddress     String?
  userAgent     String?
  requestMethod String?
  requestPath   String?

  createdAt DateTime @default(now())

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([requestId])
  @@index([ipAddress])
  @@index([requestMethod])
  @@index([createdAt])
  @@index([organizationId])
  @@map("audit_logs")
}

// ============================================================
// ✅ جدید: مدیریت صنایع، نقاط درد و کاربردها (ماژولار)
// ============================================================

model Industry {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companies Company[] @relation("CompanyIndustry")

  painPoints IndustryPainPoint[]
  useCases   IndustryUseCase[]

  @@map("industries")
}

model PainPoint {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  industries IndustryPainPoint[]

  @@map("pain_points")
}

model UseCase {
  id          String            @id @default(uuid())
  title       String
  description String?
  category    String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  industries  IndustryUseCase[]

  @@map("use_cases")
}

model IndustryPainPoint {
  id          String    @id @default(uuid())
  industryId  String
  industry    Industry  @relation(fields: [industryId], references: [id], onDelete: Cascade)
  painPointId String
  painPoint   PainPoint @relation(fields: [painPointId], references: [id], onDelete: Cascade)
  priority    Int?      @default(0)
  createdAt   DateTime  @default(now())

  @@unique([industryId, painPointId])
  @@index([industryId])
  @@index([painPointId])
  @@map("industry_pain_points")
}

model IndustryUseCase {
  id         String   @id @default(uuid())
  industryId String
  industry   Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)
  useCaseId  String
  useCase    UseCase  @relation(fields: [useCaseId], references: [id], onDelete: Cascade)
  priority   Int?     @default(0)
  createdAt  DateTime @default(now())

  @@unique([industryId, useCaseId])
  @@index([industryId])
  @@index([useCaseId])
  @@map("industry_use_cases")
}

// ============================================================
// مدیریت دسترسی‌ها (Policy)
// ============================================================

model Permission {
  id          String   @id @default(uuid())
  action      String   @unique
  name        String?
  description String?
  group       String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@map("permissions")
}

model Role {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  description String?
  baseRole    UserRole         @default(REP)
  isSystem    Boolean          @default(false)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       User[]
  permissions RolePermission[]

  @@index([isActive])
  @@map("roles")
}

model RolePermission {
  id           String     @id @default(uuid())
  role         UserRole?
  roleId       String?
  assignedRole Role?      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([role, permissionId])
  @@unique([roleId, permissionId])
  @@index([roleId])
  @@map("role_permissions")
}

model FileAttachment {
  id String @id @default(uuid())

  entityType FileAttachmentEntityType
  entityId   String

  storageProvider AttachmentStorageProvider @default(LOCAL)

  bucket      String?
  objectKey   String
  storagePath String?

  originalFileName String
  storedFileName   String

  mimeType  String
  sizeBytes Int
  sha256    String

  description String?

  uploadedById String?
  deletedAt    DateTime?
  deletedById  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String       @default("00000000-0000-4000-8000-000000000001")
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([entityType, entityId])
  @@index([storageProvider])
  @@index([bucket])
  @@index([objectKey])
  @@index([uploadedById])
  @@index([sha256])
  @@index([deletedAt])
  @@index([organizationId])
  @@index([organizationId, entityType, entityId])
  @@map("file_attachments")
}
